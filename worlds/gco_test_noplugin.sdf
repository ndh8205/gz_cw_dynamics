<?xml version="1.0" ?>
<!-- Diagnostic world: same scene as gco_test.sdf but WITHOUT the CW plugin.
     Deputy will just sit at (0, 50, 0) in zero-g. Used to isolate whether
     GUI freezes come from the plugin or from the scene/WSL path. -->
<sdf version="1.9">
  <world name="gco_test_noplugin">

    <physics name="10ms" type="dart">
      <max_step_size>0.01</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    <gravity>0 0 0</gravity>

    <gui fullscreen="0">
      <plugin filename="GzScene3D" name="3D View">
        <engine>ogre2</engine>
        <scene>scene</scene>
        <background_color>0 0 0 1</background_color>
        <camera_pose>25 -25 12 0 0.327 2.356</camera_pose>
      </plugin>
    </gui>

    <scene>
      <ambient>0.3 0.3 0.3 1</ambient>
      <background>0 0 0 1</background>
      <shadows>true</shadows>
      <grid>true</grid>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 50 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 -0.3 -0.8</direction>
    </light>

    <include>
      <uri>model://intel_sat_dummy</uri>
      <name>chief</name>
      <pose>0 0 0 0 0 0</pose>
      <static>true</static>
    </include>

    <include>
      <uri>model://nasa_satellite</uri>
      <name>deputy</name>
      <pose>0 50 0 0 0 0</pose>
    </include>

  </world>
</sdf>
